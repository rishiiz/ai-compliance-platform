# Application
PROJECT_NAME=AI Compliance Platform
DEBUG=false

# Database: PostgreSQL or MySQL. For MySQL use: mysql+pymysql://user:pass@localhost:3306/compliance_db
DATABASE_URL=postgresql://postgres:1981@localhost/compliance_db

# Use only Groq (no OpenAI): set USE_LOCAL_EMBEDDINGS=true. RAG uses local sentence-transformers; LLM uses Groq.
USE_LOCAL_EMBEDDINGS=true
# OPENAI_API_KEY=   # optional; only used for RAG when USE_LOCAL_EMBEDDINGS=false

# Groq (required for LLM: Ask policy answers, rule extraction, explanations). Get key from https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# RAG (Retrieval-Augmented Generation). Install deps: pip install -r requirements.txt (chromadb, tiktoken).
# RAG_STORAGE_BACKEND=chroma    # chroma (default, on-disk) or mysql (store in app database)
# RAG_CHROMA_PATH=              # optional; default: backend/data/chroma (used when RAG_STORAGE_BACKEND=chroma)
# RAG_ENABLED=true
# RAG_MAX_CHUNKS_PER_POLICY=200
# RAG_CHUNK_TOKENS=512
# RAG_CHUNK_OVERLAP_TOKENS=50
# RAG_TOP_K=5
# RAG_ASK_MAX_QUERY_LENGTH=500
# RAG_ASK_RATE_LIMIT_PER_HOUR=60
# RAG_LONG_POLICY_CHARS=8000

# Ask policy from company DB: when True (default), answers come from policy content in the company (external) DB.
# USE_COMPANY_DB_FOR_ASK=true
# COMPANY_POLICY_TABLE=policy_documents
# COMPANY_POLICY_CONTENT_COLUMN=content
# COMPANY_POLICY_TITLE_COLUMN=   # optional
# COMPANY_POLICY_SEARCH_LIMIT=10

# File storage: leave empty to store uploaded policy files in app database (policy_file_storage table). Or set Supabase:
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_STORAGE_BUCKET=policy-files

# API
API_V1_PREFIX=/api/v1
